# Copy this file to .env and fill in your values.
# NEVER commit .env to Git - it is listed in .gitignore.

# Discord bot token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# OpenAI-compatible API for command/game AI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://xx/v1
# Grok/xAI API for bot mentions/replies
XAI_API_KEY=
XAI_BASE_URL=https://xx/v1

# Shared Grok model for mentions/replies and !nsfw.
# Prefer GROK_MODEL. XAI_MODEL and NSFW_MODEL are still accepted as fallbacks.
GROK_MODEL=grok-4.1-fast
GROK_IMAGE_MODEL=grok-imagine-image-lite
XAI_MODEL=

# Primary command/game AI model.
# The bot owner can override this at runtime with !aimodel.
# If OPENAI_MODEL is empty, the bot uses the built-in default `gpt-5.4`.
OPENAI_MODEL=

# Optional NSFW Responses-compatible endpoint
NSFW_RESPONSES_URL=https://xx/v1/responses
NSFW_API_KEY=
# Or use the provider key name directly if you prefer:
GROK2API_API_KEY=
NSFW_MODEL=

# Your Discord user ID (right-click your name -> Copy User ID)
BOT_OWNER_ID=

# Wise sandbox token (for !liverate command, optional)
WISE_SANDBOX_TOKEN=

# Cloudflare Worker URL for !ck check-in command (optional)
CHECKIN_WORKER_URL=

# Auth password for the check-in Worker (optional)
CHECKIN_AUTH_PASS=
