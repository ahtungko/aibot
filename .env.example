# Copy this file to .env and fill in your values.
# NEVER commit .env to Git - it is listed in .gitignore.

# Discord bot token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# Grok/xAI API key
# OPENAI_API_KEY=
XAI_API_KEY=

# Grok responses base URL for mentions and !tldr
# OPENAI_BASE_URL=
XAI_BASE_URL=https://xx/v1

# Primary AI model for mentions and !tldr
XAI_MODEL=grok-4.1-fast

# Optional NSFW Responses-compatible endpoint
NSFW_RESPONSES_URL=https://xx/v1/responses
NSFW_API_KEY=
# Or use the provider key name directly if you prefer:
GROK2API_API_KEY=
NSFW_MODEL=grok-4

# Your Discord user ID (right-click your name -> Copy User ID)
BOT_OWNER_ID=

# Wise sandbox token (for !liverate command, optional)
WISE_SANDBOX_TOKEN=

# Cloudflare Worker URL for !ck check-in command (optional)
CHECKIN_WORKER_URL=

# Auth password for the check-in Worker (optional)
CHECKIN_AUTH_PASS=
